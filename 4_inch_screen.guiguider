																									"inc_c": "",
																									"code_c": "/* 点开关 → 读它点击后的新状态 → 写回中间层 → 刷 small_dev_off 透明度。 */\r\nlv_obj_t *btn = lv_event_get_target(e);                    /* 触发事件的开关本身 */\r\nbool light_on = lv_obj_has_state(btn, LV_STATE_CHECKED);   /* 有CHECKED=开, 没有=关 */\r\n\r\nHWInterface.LightCT.SetOnOff(light_on);   /* 写回中间层: 开→true, 关→false; 与 screen_5 共享同一份 */\r\n\r\n/* small_dev_off: 开→LV_OPA_TRANSP(0%, 隐藏), 关→LV_OPA_COVER(100%, 显示) */\r\nlv_obj_set_style_img_opa(guider_ui.device_management_screen_small_dev_off_img,\r\n                         light_on ? LV_OPA_TRANSP : LV_OPA_COVER,\r\n                         LV_PART_MAIN | LV_STATE_DEFAULT);",
																									"inc_py": "",
																									"code_py": ""
																								}
																							}
																						}
																					]
																				}
