																		"event": {
																			"widget": {
																				"value_changed": {
																					"condition": [],
																					"action": [
																						{
																							"dst": "custom_code",
																							"bindCondi": "",
																							"actionList": {
																								"custom_code": {
																									"inc_c": "static uint32_t s_ct_apply_tick;",
																									"code_c": "const uint32_t APPLY_MIN_MS = 50;   /* 拖动节流: 两张旋转灯光图重绘很重, 最多每 50ms 刷一次防卡 */\r\nif (lv_tick_elaps(s_ct_apply_tick) >= APPLY_MIN_MS) {\r\n    s_ct_apply_tick = lv_tick_get();\r\n\r\n    lv_obj_t *slider1 = guider_ui.screen_5_slider_1;   /* 亮度 0..100 */\r\n    lv_obj_t *slider2 = guider_ui.screen_5_slider_2;   /* 色温 2700..6500 */\r\n    lv_obj_t *white   = guider_ui.screen_5_dev_white_img;\r\n    lv_obj_t *orange  = guider_ui.screen_5_dev_orange_img;\r\n\r\n    if (lv_obj_is_valid(slider1) && lv_obj_is_valid(slider2)) {\r\n        const int32_t CT_MIN  = 2700;   /* 色温最左(K) */\r\n        const int32_t CT_SPAN = 3800;   /* 6500-2700 */\r\n        const int32_t BRI_MAX = 100;\r\n        int32_t  bri  = lv_slider_get_value(slider1);\r\n        int32_t  ct   = lv_slider_get_value(slider2);\r\n        uint32_t tnum = (uint32_t)(ct - CT_MIN);                                 /* = T*CT_SPAN */\r\n        uint32_t o_white  = (uint32_t)bri * tnum            * LV_OPA_COVER / ((uint32_t)BRI_MAX * CT_SPAN);\r\n        uint32_t o_orange = (uint32_t)bri * (CT_SPAN - tnum) * LV_OPA_COVER / ((uint32_t)BRI_MAX * CT_SPAN);\r\n        if (lv_obj_is_valid(white))  lv_obj_set_style_img_opa(white,  (lv_opa_t)o_white,  LV_PART_MAIN | LV_STATE_DEFAULT);\r\n        if (lv_obj_is_valid(orange)) lv_obj_set_style_img_opa(orange, (lv_opa_t)o_orange, LV_PART_MAIN | LV_STATE_DEFAULT);\r\n    }\r\n}",
																									"inc_py": "",
																									"code_py": ""
																								}
																							}
																						}
																					]
																				}
																			}
																		},
																		"layerName": "screen_5"
																	},
