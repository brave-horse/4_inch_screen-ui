																	"code_c": "/* 进屏初始化: 从中间层读色温灯开关真值, 摆正开关 CHECKED + small_dev_off 透明度。 */\r\nbool light_on = HWInterface.LightCT.switch_status;   /* true=开, false=关 */\r\n\r\n/* 开关图标 CHECKED 摆到当前状态 */\r\nif (light_on) lv_obj_add_state(guider_ui.device_management_screen_Light_CT_on_off_1_img, LV_STATE_CHECKED);\r\nelse          lv_obj_clear_state(guider_ui.device_management_screen_Light_CT_on_off_1_img, LV_STATE_CHECKED);\r\n\r\n/* small_dev_off: 开→LV_OPA_TRANSP(0%, 隐藏), 关→LV_OPA_COVER(100%, 显示) */\r\nlv_obj_set_style_img_opa(guider_ui.device_management_screen_small_dev_off_img,\r\n                         light_on ? LV_OPA_TRANSP : LV_OPA_COVER,\r\n                         LV_PART_MAIN | LV_STATE_DEFAULT);\r\n",
																	"inc_py": "",
																	"code_py": ""
																}
															}
														},
														{
															"dst": "custom_code",
															"bindCondi": "",
															"actionList": {
																"custom_code": {
																	"inc_c": "#include  \"img.h\"",
																	"code_c": "",
																	"inc_py": "",
																	"code_py": ""
																}
															}
														}
													]
												}
											}
										},
